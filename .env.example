OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789/gateway
OPENCLAW_TOKEN=change-me
OPENCLAW_TIMEOUT_SECONDS=20
OPENCLAW_RECONNECT_MAX_ATTEMPTS=3
OPENCLAW_ALLOWED_METHODS=connect,agent.list,agent.run,memory.read,memory.write,health.ping
OPENCLAW_ALLOWLIST_POLICY=strict
OPENCLAW_DISPATCH_MODE=auto
OPENCLAW_WEBHOOK_URL=

FIRM_REPO_PATH=
FIRM_REPO_URL=https://github.com/romainsantoli-web/setup-vs-agent-firm.git
FIRM_REPO_BRANCH=main
FIRM_REPO_AUTO_SYNC=false
READ_ONLY_MODE=true
LOG_LEVEL=INFO
MCP_TRANSPORT=streamable-http
MCP_MOUNT_PATH=
MCP_HOST=127.0.0.1
MCP_PORT=8011

ROUTING_MODE=quality-first
ROUTING_DEFAULT_TASK_FAMILY=research
ROUTING_DEFAULT_QUALITY_TIER=high
ROUTING_DEFAULT_PROFILE=analysis-deep
ROUTING_ALLOWED_PROFILES=creative-premium,creative-shortform,creative-longform,planning-strategic,translation-precision,translation-localization,translation-seo,reasoning-technical,debug-root-cause,debug-patch,analysis-deep,analysis-synthesis,analysis-comparison
ROUTING_ENABLE_COPILOT_HINTS=true
ROUTING_ENABLE_AGENT_COPILOT_ACCESS=true

SECURE_PRODUCTION_MODE=false
POLICY_BLOCKED_TOOLS=
POLICY_ALLOW_WRITE_TOOLS=false
POLICY_ALLOW_NETWORK_TOOLS=true

AUDIT_ENABLED=true
AUDIT_FILE_PATH=

MEMORY_BACKEND=memory_os_ai
MEMORY_SQLITE_PATH=
MEMORY_OS_AI_REPO_PATH=
MEMORY_OS_AI_EVENTS_PATH=
MEMORY_OS_AI_CONTEXT_LIMIT=16
MEMORY_BRIDGE_ENABLED=true
MEMORY_BRIDGE_HOST=127.0.0.1
MEMORY_BRIDGE_PORT=9120
MEMORY_BRIDGE_QUERY_PATH=/context/query
MEMORY_BRIDGE_TIMEOUT_SECONDS=3
MEMORY_BRIDGE_USE_IN_CONTEXT=true

TELEMETRY_ENABLED=true
WORKFLOW_MAX_ATTEMPTS=2
WORKFLOW_IDEMPOTENCY_ENABLED=true
WORKFLOW_STORE_PATH=

PLUGINS_ENABLED=enforce_objective_min_length,normalize_departments
PLUGIN_ENFORCE_OBJECTIVE_MIN_LENGTH=24
PLUGIN_POLICY_MODE=enforce

COST_GUARD_ENABLED=true
COST_GUARD_POLICY_MODE=enforce
COST_GUARD_PER_RUN_BUDGET=2.5
COST_GUARD_DAILY_BUDGET=25.0
COST_GUARD_LEDGER_PATH=

PROMETHEUS_EXPORTER_ENABLED=true
PROMETHEUS_EXPORTER_HOST=127.0.0.1
PROMETHEUS_EXPORTER_PORT=9108
PROMETHEUS_EXPORTER_PATH=/metrics
