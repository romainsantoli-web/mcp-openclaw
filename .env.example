OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789/gateway
OPENCLAW_TOKEN=change-me
OPENCLAW_TIMEOUT_SECONDS=20
OPENCLAW_RECONNECT_MAX_ATTEMPTS=3
OPENCLAW_ALLOWED_METHODS=connect,agent.list,agent.run,memory.read,memory.write,health.ping
OPENCLAW_ALLOWLIST_POLICY=strict
OPENCLAW_DISPATCH_MODE=auto
OPENCLAW_WEBHOOK_URL=

FIRM_REPO_PATH=
FIRM_REPO_URL=https://github.com/romainsantoli-web/setup-vs-agent-firm.git
FIRM_REPO_BRANCH=main
FIRM_REPO_AUTO_SYNC=false
READ_ONLY_MODE=true
LOG_LEVEL=INFO
MCP_TRANSPORT=streamable-http
MCP_MOUNT_PATH=
MCP_HOST=127.0.0.1
MCP_PORT=8011

ROUTING_MODE=quality-first
ROUTING_DEFAULT_TASK_FAMILY=research
ROUTING_DEFAULT_QUALITY_TIER=high
ROUTING_DEFAULT_PROFILE=analysis-deep
ROUTING_ALLOWED_PROFILES=creative-premium,translation-precision,reasoning-technical,analysis-deep
ROUTING_ENABLE_COPILOT_HINTS=true
