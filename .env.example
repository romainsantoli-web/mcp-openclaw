OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789/gateway
OPENCLAW_TOKEN=change-me
OPENCLAW_TIMEOUT_SECONDS=20
OPENCLAW_RECONNECT_MAX_ATTEMPTS=3
OPENCLAW_ALLOWED_METHODS=connect,agent.list,agent.run,memory.read,memory.write,health.ping

FIRM_REPO_PATH=
READ_ONLY_MODE=true
LOG_LEVEL=INFO
MCP_TRANSPORT=streamable-http
MCP_MOUNT_PATH=
MCP_HOST=127.0.0.1
MCP_PORT=8011
