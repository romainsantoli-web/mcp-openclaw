# mcp-openclaw-extensions — environment configuration
# Copy to .env and fill in your values
# Never commit .env to git

# ── MCP server ───────────────────────────────────────────────
MCP_EXT_HOST=127.0.0.1
MCP_EXT_PORT=8012
LOG_LEVEL=INFO

# ── OpenClaw Gateway ─────────────────────────────────────────
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_HTTP=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your_token_here
OPENCLAW_TIMEOUT_SECONDS=15

# ── VS Code Bridge ───────────────────────────────────────────
VS_BRIDGE_MAX_CONTEXT_BYTES=32768

# ── Fleet Manager ────────────────────────────────────────────
FLEET_CONFIG_PATH=~/.openclaw/fleet.json
FLEET_MAX_INSTANCES=50
FLEET_HEALTH_TIMEOUT_SECONDS=8
FLEET_BROADCAST_TIMEOUT_SECONDS=20

# ── Delivery Export ──────────────────────────────────────────
FIRM_EXPORT_OUTPUT_DIR=~/.openclaw/exports
EXPORT_HTTP_TIMEOUT_SECONDS=20
EXPORT_MAX_BODY_CHARS=64000

# GitHub (for firm_export_github_pr)
# Fine-grained token: needs Contents (write) + Pull requests (write)
# GITHUB_TOKEN=ghp_your_token_here

# Jira (for firm_export_jira_ticket)
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_BASE_URL=https://yourorg.atlassian.net
# JIRA_USER_EMAIL=you@yourorg.com

# Linear (for firm_export_linear_issue)
# LINEAR_API_KEY=lin_api_your_key

# Slack (for firm_export_slack_digest)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
